/**
 * Updated ruleset with role-based access control (RBAC).
 * Roles: super_admin (hardcoded), evaluator, jury (stored in user_roles collection).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ───────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** Super admins — hardcoded email list. */
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "t20avnish@gmail.com" ||
        request.auth.token.email == "sagun.kumari@timesinternet.in"
      );
    }

    // Alias kept for backward compat
    function isAdmin() {
      return isSuperAdmin();
    }

    /**
     * Reads the user_roles doc for the signed-in user.
     * NOTE: These get() calls count toward Firestore read limits but are
     * the standard pattern for role-based access without custom claims.
     */
    function getUserRole() {
      return get(/databases/$(database)/documents/user_roles/$(request.auth.token.email)).data.role;
    }

    function isEvaluator() {
      return isSignedIn() && getUserRole() == "evaluator";
    }

    function isJury() {
      return isSignedIn() && getUserRole() == "jury";
    }

    function canWriteDraft(userId) {
      return isOwner(userId) &&
        request.resource.data.userId == userId &&
        (resource == null || request.resource.data.userId == resource.data.userId);
    }

    function isCreatingOwnSubmission(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }

    // Only allow evaluator to update status-related fields (not form data)
    function isEvaluatorStatusUpdate() {
      return isEvaluator() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "statusUpdatedAt", "statusUpdatedBy"]);
    }

    // ── Collection Rules ───────────────────────────────────────────────────

    /** Form configurations — public read, super admin write. */
    match /form_configurations/{formConfigurationId} {
      allow get, list: if true;
      allow create: if isSuperAdmin();
      allow update, delete: if isSuperAdmin() && resource != null;
    }

    /**
     * user_roles — Super admin manages all. Any signed-in user can read their
     * own role doc (needed to determine redirect after login).
     */
    match /user_roles/{email} {
      allow get: if isSignedIn() && (request.auth.token.email == email || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    /** User root documents. */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow list: if false;
      allow delete: if false;
    }

    /** Drafts — user-owned. */
    match /users/{userId}/drafts/{formConfigurationId} {
      allow get, list: if isOwner(userId);
      allow write: if canWriteDraft(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * Submissions — specific-path rule.
     * Owners & super admins can read. Evaluators can read + update status only.
     * Nobody (including jury/evaluator) can edit form data.
     */
    match /users/{userId}/submissions/{submissionId} {
      allow get, list: if isOwner(userId) || isSuperAdmin() || isEvaluator() || isJury();
      allow create: if isCreatingOwnSubmission(userId);
      allow update: if isSuperAdmin() || isEvaluatorStatusUpdate();
      allow delete: if false;
    }

    /**
     * Wildcard rule for collectionGroup("submissions") queries.
     * Required for cross-collection queries from evaluator/jury/super admin views.
     */
    match /{path=**}/submissions/{submissionId} {
      allow read: if isSuperAdmin() || isEvaluator() || isJury();
      allow update: if isSuperAdmin() || isEvaluatorStatusUpdate();
    }
  }
}
